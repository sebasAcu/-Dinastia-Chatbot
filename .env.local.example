# ── Autenticación ──────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Contraseña única para acceder al dashboard
DASHBOARD_PASSWORD=tu-contraseña-segura

# ── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ── WhatsApp Webhook (Meta API - ya no requerido con Baileys) ──
WHATSAPP_VERIFY_TOKEN=tu-token-de-verificacion-webhook

# ── Baileys Server ─────────────────────────────────────────
# URL donde corre el servidor Baileys (Railway, Render, VPS, etc.)
BAILEYS_SERVER_URL=http://localhost:3001
# Secret compartido entre Next.js y el servidor Baileys
BAILEYS_SECRET=cambia_esto_por_un_secret_seguro
